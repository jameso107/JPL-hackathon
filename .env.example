# ChatHPC (JPL) LLM backend — used ONLY by the server proxy / Vercel function.
# Never exposed to the browser. Copy to .env for local dev; set these as
# Environment Variables in the Vercel project for deployment.
CHATHPC_BASE_URL=https://chathpc.jpl.nasa.gov/api
CHATHPC_API_KEY=replace-with-your-key
CHATHPC_MODEL=gemma4:31b-128k
# Local dev proxy port (vite dev server proxies /api here)
PROXY_PORT=8787
